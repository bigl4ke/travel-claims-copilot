# Server-side OpenAI credential. Never prefix it with NEXT_PUBLIC_ or commit a value.
OPENAI_API_KEY=

# The only default and demonstrated extraction model.
OPENAI_INTAKE_MODEL=gpt-5.6-luna

# Server-side judge/demo gate for GPT mode. Enter a strong value directly in the host dashboard.
DEMO_ACCESS_CODE=

# Global deployment controls are configured outside process memory: 10 GPT requests/IP/minute,
# 60/IP/hour, and 2 concurrent/IP, plus an OpenAI project spend limit. If those controls cannot be
# proved across instances, keep DEMO_ACCESS_CODE enabled and do not expose GPT mode unrestricted.

# Supplied automatically by Vercel for Git-backed deployments; otherwise use the deployed 40-hex SHA.
VERCEL_GIT_COMMIT_SHA=

# Public non-secret application version shown by /api/health.
APP_VERSION=0.1.0
