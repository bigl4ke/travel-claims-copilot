# Server-side only. Never use NEXT_PUBLIC_* for API keys.
# Optional: set to openai or deepseek. When omitted, the configured key/model/base URL is used.
# LLM_PROVIDER=openai

# OpenAI Responses API
OPENAI_API_KEY=
# OPENAI_INTAKE_MODEL=gpt-5.6-luna
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek Chat Completions API
# DEEPSEEK_API_KEY=
# DEEPSEEK_INTAKE_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
